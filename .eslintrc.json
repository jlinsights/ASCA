{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "react/no-unescaped-entities": "off",
    "@next/next/no-page-custom-font": "off",
    "no-console": "warn",
    "react-hooks/exhaustive-deps": "warn",
    "prefer-const": "error",
    "no-var": "error",
    "max-lines": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "TemplateElement[tail=false][value.raw=/(^|[ :])(bg|text|border|ring|from|to|via|fill|stroke)-$/]",
        "message": "동적 Tailwind 클래스 금지 — `bg-${...}` 등은 JIT가 생성하지 못해 프로덕션 CSS에서 누락됩니다. 정적 클래스 lookup 맵(components/cultural/_constants/color-classes.ts 패턴)을 사용하세요. DESIGN.md §10 참조."
      }
    ]
  },
  "overrides": [
    {
      "files": ["app/admin/**/*.tsx", "app/admin/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "**/app/profile/membership/_components/*",
              "**/components/gallery/dashboard/*"
            ]
          }
        ]
      }
    },
    {
      "files": ["**/__tests__/**/*", "**/*.test.ts", "**/*.test.tsx", "e2e/**/*"],
      "rules": {
        "max-lines": "off",
        "no-console": "off"
      }
    },
    {
      "files": ["scripts/**/*", "tools/**/*", "ops/**/*"],
      "rules": {
        "no-console": "off",
        "max-lines": "off"
      }
    },
    {
      "files": ["lib/logging/**/*", "lib/config/env.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["lib/db/schema.ts", "lib/db/schema-pg.ts"],
      "rules": {
        "max-lines": "off"
      }
    },
    {
      "files": ["lib/db/seed/**/*", "lib/db/seed*.ts"],
      "rules": {
        "no-console": "off",
        "max-lines": "off"
      }
    },
    {
      // shadcn/ui vendor (radix slot·cva·forwardRef) — 상류 재생성/업데이트와 발산 방지: 분리하지 않고 단일 파일 예외 (design §4)
      "files": ["components/ui/sidebar.tsx"],
      "rules": {
        "max-lines": "off"
      }
    },
    {
      // a11y 회귀 게이트 — asca-a11y-cleanup 사이클에서 정리된 디렉터리만 error 승격.
      // 전역 승격은 기존 위반 218건(99파일)이라 불가 — 롤아웃은 asca-a11y-rules-rollout 후속 사이클.
      "files": [
        "components/gallery/artwork-comparison/**/*.tsx",
        "components/gallery/gallery-grid/**/*.tsx",
        "components/gallery/stroke-animation/**/*.tsx",
        "components/gallery/zoomable-image-viewer/**/*.tsx",
        "components/cultural/cultural-accessibility/**/*.tsx",
        "components/cultural/cultural-calendar/**/*.tsx",
        "components/cultural/learning-hub/**/*.tsx",
        "components/cultural/virtual-exhibition/**/*.tsx"
      ],
      "rules": {
        "jsx-a11y/label-has-associated-control": "error",
        "jsx-a11y/control-has-associated-label": "error",
        "jsx-a11y/click-events-have-key-events": "error",
        "jsx-a11y/no-static-element-interactions": "error",
        "react/no-array-index-key": "error"
      }
    }
  ]
}
