.next/
out/

# production
.env.local
.env.development.local
.env.test.local
.env.production.local
.DS_Store
*.tgz
*.tar.gz
.cache/
dist/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
